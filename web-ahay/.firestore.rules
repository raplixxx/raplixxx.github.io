rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function: Check if user owns the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Helper function: Get user's uniqueLinkId
    function getUserLinkId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.uniqueLinkId;
    }
    
    // Users collection
    match /users/{userId} {
      // Only the owner can read their own profile
      allow read: if isAuthenticated() && isOwner(userId);
      
      // Anyone can create a new user profile for themselves
      allow create: if isAuthenticated() && isOwner(userId);
      
      // Only owner can update their profile
      allow update: if isAuthenticated() && isOwner(userId) 
        && request.resource.data.email == resource.data.email
        && request.resource.data.createdAt == resource.data.createdAt;
      
      // Never allow deletion
      allow delete: if false;
      
      // Allow checking username uniqueness (limited read)
      match /username {
        allow read: if true;
      }
    }
    
    // Chats collection
    match /chats/{uniqueLinkId} {
      // Only the owner of this link can access
      allow read, write: if isAuthenticated() 
        && getUserLinkId() == uniqueLinkId;
      
      // Sessions subcollection
      match /sessions/{sessionId} {
        // Only chat owner can read/write sessions
        allow read, write: if isAuthenticated() 
          && getUserLinkId() == uniqueLinkId;
        
        // Messages subcollection within sessions
        match /messages/{messageId} {
          // Only chat owner can read/write messages
          allow read, write: if isAuthenticated() 
            && getUserLinkId() == uniqueLinkId;
          
          // Validate message structure
          allow create: if isAuthenticated() 
            && getUserLinkId() == uniqueLinkId
            && request.resource.data.role in ['user', 'assistant', 'tool']
            && request.resource.data.content is string
            && request.resource.data.timestamp == request.time;
          
          // Allow updates for editing messages (within 5 minutes)
          allow update: if isAuthenticated() 
            && getUserLinkId() == uniqueLinkId
            && request.resource.data.role == resource.data.role
            && request.time - resource.data.timestamp < duration.time(5, "m");
          
          // Never allow deletion of messages
          allow delete: if false;
        }
      }
    }
    
    // Shared chats - public read only
    match /shared_chats/{shareId} {
      // Anyone can read shared chats (no auth required)
      allow read: if true;
      
      // Only authenticated users can create shared chats
      allow create: if isAuthenticated()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.messages is list
        && request.resource.data.messages.size() > 0
        && request.resource.data.messages.size() <= 200;
      
      // Only creator can delete their shared chats
      allow delete: if isAuthenticated()
        && request.auth.uid == resource.data.createdBy;
      
      // No updates allowed for shared chats
      allow update: if false;
    }
    
    // Usernames collection for uniqueness
    match /usernames/{username} {
      // Anyone can check if username exists
      allow read: if true;
      
      // Only authenticated users can claim a username
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && username == request.resource.data.username
        && username.matches('^[a-z0-9]{3,20}$');
      
      // No updates or deletes
      allow update, delete: if false;
    }
    
    // Default deny for any other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
